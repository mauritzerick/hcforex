# API base URL (no trailing slash). In dev set to http://localhost:3000
VITE_API_URL=http://localhost:3000

# GetKollo SDK (embedded card form). Required for Card page.
# Your domain (e.g. your-app.vercel.app) must be registered with Hello Clever for this app_id.
# VITE_GETKOLLO_APP_ID=your-app-id
# Prod SDK is used by default. For sandbox testing set:
# VITE_GETKOLLO_SDK_URL=https://cdn.lightningpay.me/media/getkollo-sdk/1.1.0/sandbox/getkollo.js
# Prod: https://cdn.lightningpay.me/media/getkollo-sdk/1.1.0/prod/getkollo.js
