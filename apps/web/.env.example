# API base URL (no trailing slash). In dev set to http://localhost:3000
VITE_API_URL=http://localhost:3000

# GetKollo SDK (embedded card form). Optional; Card page uses sandbox by default.
# Your domain (e.g. localhost:5173) must be registered with Hello Clever for this app_id.
# Use sandbox app_id with sandbox SDK URL, or production app_id with production SDK URL.
# VITE_GETKOLLO_APP_ID=your-app-id
# VITE_GETKOLLO_SDK_URL=https://cdn.lightningpay.me/media/getkollo-sdk/1.1.0/sandbox/getkollo.js
# Production: https://cdn.lightningpay.me/media/getkollo-sdk/1.1.0/prod/getkollo.js
