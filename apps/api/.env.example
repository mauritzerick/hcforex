# Hello Clever API (payin proxy) – one app ID and one secret key per currency
HELLOCLEVER_APP_ID_IDR=
HELLOCLEVER_SECRET_KEY_IDR=
HELLOCLEVER_APP_ID_VND=
HELLOCLEVER_SECRET_KEY_VND=
HELLOCLEVER_APP_ID_KRW=
HELLOCLEVER_SECRET_KEY_KRW=
HELLOCLEVER_APP_ID_JPY=
HELLOCLEVER_SECRET_KEY_JPY=

# Optional
PORT=3000
HELLOCLEVER_BASE_URL=https://api-merchant.helloclever.co/api/v2
# Comma-separated CORS origins for production (e.g. https://your-app.vercel.app). *.vercel.app is allowed by default.
# ALLOWED_ORIGINS=https://idr-brick.vercel.app
